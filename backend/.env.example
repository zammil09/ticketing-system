# ===== قاعدة البيانات =====
# مثال محلي: postgresql://postgres:yourpassword@localhost:5432/ticketing_system
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/ticketing_system

# ===== الاتصال بالسلسلة (نفس رابط Sepolia المستخدم بالنشر) =====
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# ===== عناوين العقود (بعد النشر من الخطوة ١) =====
REGISTRY_ADDRESS=0xPUT_EVENTREGISTRY_ADDRESS_HERE
MARKETPLACE_ADDRESS=0xPUT_MARKETPLACE_ADDRESS_HERE
TICKET_NFT_ADDRESS=0xPUT_TICKETNFT_ADDRESS_HERE

# رقم البلوك اللي انُشر فيه أول عقد (يخلي الـ Indexer يبدأ من هناك بدل الصفر — أسرع بكثير)
DEPLOY_BLOCK=0

PORT=4000

# ===== إرسال إيميل التذكرة (اختياري تماماً) =====
# اتركها فاضية لو ما تبي هالخاصية — التطبيق يشتغل عادي بدونها (QR يبقى بالتطبيق فقط)
# مثال بستخدام Gmail: فعّل "App Passwords" من إعدادات حساب Google أولاً
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=your_email@gmail.com
